{
  "name": "daycal",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "eslint",
    "electron:dev": "next build && electron .",
    "electron:build": "next build && electron-builder"
  },
  "build": {
    "appId": "com.daycal.app",
    "productName": "DayCal",
    "asar": true,
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "public/icon-512.png",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ]
    },
    "dmg": {
      "title": "DayCal",
      "window": { "width": 540, "height": 380 }
    },
    "directories": {
      "output": "dist",
      "buildResources": "public"
    },
    "files": [
      "out/**/*",
      "electron/**/*",
      "node_modules/electron-serve/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "date-fns": "^4.1.0",
    "electron-serve": "^3.0.1",
    "firebase": "^12.11.0",
    "lucide-react": "^1.0.1",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hot-toast": "^2.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
